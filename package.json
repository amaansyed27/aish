{
  "name": "aish",
  "version": "0.1.0",
  "private": true,
  "description": "AiSH intelligent terminal app and shell/provider layer.",
  "workspaces": [
    "apps/desktop",
    "apps/site"
  ],
  "scripts": {
    "site:dev": "npm --workspace apps/site run dev",
    "site:build": "npm --workspace apps/site run build",
    "site:preview": "npm --workspace apps/site run preview",
    "desktop:dev": "npm --workspace apps/desktop run tauri dev",
    "desktop:build": "npm --workspace apps/desktop run tauri build",
    "desktop:check": "npm --workspace apps/desktop run typecheck",
    "provider:build": "cargo build --release -p aish-provider-shell",
    "provider:dev": "cargo run -p aish-provider-shell",
    "package:all": "npm run desktop:build && npm run provider:build"
  }
}
