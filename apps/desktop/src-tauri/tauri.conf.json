{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AiSH",
  "version": "0.1.0",
  "identifier": "labs.dawnlight.aish",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AiSH",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Dawnlight Labs",
    "homepage": "https://dawnlightlabs.com/aish",
    "copyright": "Copyright (c) 2026 Dawnlight Labs. All rights reserved.",
    "license": "MIT",
    "shortDescription": "AiSH AI-native shell and desktop terminal",
    "longDescription": "AiSH is an AI-native provider shell and desktop terminal from Dawnlight Labs.",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
