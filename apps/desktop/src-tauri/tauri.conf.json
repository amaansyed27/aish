{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AiSH",
  "version": "0.1.0",
  "identifier": "dev.aish.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AiSH",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "AiSH AI-native shell and desktop terminal",
    "longDescription": "AiSH packages an AI Run provider shell plus an optional desktop terminal app.",
    "category": "DeveloperTool",
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
